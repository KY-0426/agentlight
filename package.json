{
  "name": "agent-light",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "server",
    "packages/*"
  ],
  "bin": {
    "agent-light": "./bin/agent-light.mjs"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "dev:all": "node ./scripts/dev-all.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "test": "vitest run",
    "test:shared": "npm --workspace @agent-light/shared run test",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test && npm run test:shared && npm run server:test && npm run test:rust",
    "assets:placeholder": "node ./scripts/generate-placeholder-assets.mjs",
    "assets:frames": "node ./scripts/generate-pet-frames.mjs",
    "shared:build": "npm --workspace @agent-light/shared run build",
    "server:dev": "npm --workspace @agent-light/server run dev",
    "server:test": "npm --workspace @agent-light/server run test",
    "db:migrate": "npm --workspace @agent-light/server run db:migrate",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/win-dev.ps1",
    "run:windows": "powershell -ExecutionPolicy Bypass -File ./scripts/run-agent-light.ps1",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --bundles nsis",
    "tauri:build:macos": "tauri build --bundles dmg",
    "agent-light": "node ./bin/agent-light.mjs"
  },
  "dependencies": {
    "@agent-light/shared": "0.1.0",
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
